{
    "name": "Hermes Desktop",
    "names": {
        "zh-Hans": "Hermes 桌面端"
    },
    "category": "Desktop",
    "apiProtocol": [
        "openai"
    ],
    "docs": "https://hermes-agent.nousresearch.com/docs/",
    "website": "https://github.com/NousResearch/hermes-agent",
    "command": "hermes",
    "startCommand": "hermes",
    "envVar": "HERMES_HOME",
    "configDir": "~/.hermes",
    "configDirAlt": "%LOCALAPPDATA%\\hermes",
    "configFile": "~/.hermes/config.yaml",
    "configFileAlt": "%LOCALAPPDATA%\\hermes\\config.yaml",
    "requireConfigFile": false,
    "detectByConfigDir": true,
    "paths": {
        "win32": [
            "%LOCALAPPDATA%\\hermes\\hermes-agent\\venv\\Scripts\\hermes.exe"
        ],
        "darwin": [
            "/usr/local/bin/hermes",
            "/opt/homebrew/bin/hermes"
        ],
        "linux": [
            "/usr/local/bin/hermes",
            "/usr/bin/hermes",
            "~/.local/bin/hermes",
            "~/.hermes/hermes-agent/venv/bin/hermes"
        ]
    },
    "skillsPath": {
        "darwin": [
            "~/.hermes/skills"
        ],
        "linux": [
            "~/.hermes/skills"
        ]
    }
}
